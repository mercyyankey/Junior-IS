@article{chan2025xr,
  author = {Chan, Venus},
  title = {Investigating the Effects of Extended Reality (XR) on Interpreter Competencies: An Experimental Study of a Pioneering XR Mobile-Assisted Language Learning Application for Interpreting Training},
  journal = {Journal of Computer Assisted Learning},
  year = {2025},
  volume = {41},
  pages = {e70055},
  doi = {10.1111/jcal.70055},
  annote = {This article examines whether extended reality tools can strengthen interpreting training through a mobile-assisted language learning platform. The author argues that conventional classroom instruction often lacks the contextual and visual cues that shape real interpreting work. Using a ten-week quasi-experimental design, the study compares students who used the XR system with a control group and measures changes in both conceptual understanding and practical performance. The findings suggest stronger gains for the XR group, indicating that immersive digital environments can support skill development in applied language training. This source is useful for research on decision-making in language learning systems because it shows how platform design can shape learner performance and assessment.}
}

@article{dayanand2025irula,
  author = {Dayanand, Arul and Devi, Uma and Jinu, Kevin Thomas and Siddiqui, Mohammed Ariz and Thekkudan, Evina Novi},
  title = {Revitalising the Irula Language Through Mobile Language Learning Application},
  journal = {Cureus Journal of Computer Science},
  year = {2025},
  volume = {2},
  pages = {es44389-025-08635-7},
  doi = {10.7759/s44389-025-08635-7},
  url = {https://doi.org/10.7759/s44389-025-08635-7},
  annote = {This article focuses on the use of a mobile-assisted language learning application to support the preservation of the endangered Irula language. The authors connect language loss to social pressures, reduced intergenerational transmission, and limited learning resources for younger speakers. They describe the design of a mobile app built through an Agile process, with features such as audio support, multilingual interfaces, and vocabulary-based practice. Testing across several devices emphasizes usability, responsiveness, and accessibility for learners. This source is relevant because it shows how technical design choices in a language app can influence participation, learning access, and long-term sustainability.}
}

@inproceedings{hug2025ai_literacy,
  author = {Hug, Sarah and McKay, Mark},
  title = {Problematizing AI Literacy Access: Understanding Student AI Literacy from Student Voices},
  booktitle = {Proceedings of the 2025 Conference on Research on Equitable and Sustained Participation in Engineering, Computing, and Technology (RESPECT 2025)},
  year = {2025},
  publisher = {Association for Computing Machinery},
  address = {Newark, NJ, USA},
  doi = {10.1145/3704637.3734789},
  isbn = {9798400713552},
  annote = {This paper investigates how low-income computer science students think about and use generative AI tools in academic settings. Drawing on qualitative interviews, the authors show that students often make decisions about tools like ChatGPT without consistent institutional guidance. Many participants rely on personal judgment, trial and error, and peer norms when deciding whether AI use is appropriate or helpful. The study also highlights unequal access to AI literacy and the effects of mixed messages from instructors and institutions. This source is useful because it connects user decision-making with broader questions of access, policy, and responsible use of computational systems.}
}

@article{montrul2008gender,
  author = {Montrul, Silvina and Foote, Rebecca and Perpi\~n\'an, Silvia},
  title = {Gender Agreement in Adult Second Language Learners and Spanish Heritage Speakers: The Effects of Age and Context of Acquisition},
  journal = {Language Learning},
  year = {2008},
  volume = {58},
  number = {3},
  pages = {503--553},
  publisher = {Language Learning Research Club, University of Michigan},
  doi = {10.1111/j.1467-9922.2008.00457.x},
  annote = {This article compares gender agreement patterns in adult second-language learners of Spanish and Spanish heritage speakers. Montrul, Foote, and Perpi\~n\'an examine how age of acquisition and learning context shape grammatical performance, especially in an area of Spanish that often reveals differences between learner groups. The study is useful because it highlights that heritage speakers do not fit neatly into either monolingual or traditional second-language categories. Instead, their language development reflects a distinct combination of early exposure, reduced input, and later formal instruction. This source is relevant to a literature review on heritage language learning because it provides evidence that learning background affects grammatical competence in measurable ways.}
}

@article{levy2009technology,
  author = {Levy, Mike},
  title = {Technologies in Use for Second Language Learning},
  journal = {The Modern Language Journal},
  year = {2009},
  volume = {93},
  pages = {769--782},
  publisher = {Wiley},
  doi = {10.1111/j.1540-4781.2009.00972.x},
  url = {https://www.jstor.org/stable/25612273},
  annote = {In this article, Levy reviews the kinds of technologies being used in second language learning and considers how they shape language instruction and learner interaction. Rather than focusing on a single tool, he surveys broader technological developments and shows how digital resources have become integrated into language teaching practice. The article is valuable because it gives a foundation for understanding computer-assisted language learning as a field, especially before more recent work on mobile and immersive systems. It is relevant to a literature review on digital language learning because it helps situate newer applications within a longer history of technology use in language education.} 
}

@book{montrul2016heritage,
  author = {Montrul, Silvina},
  title = {The Acquisition of Heritage Languages},
  publisher = {Cambridge University Press},
  year = {2016},
  address = {Cambridge, United Kingdom},
  isbn = {9781107007246},
  url = {https://www.cambridge.org/9781107007246},
  annote = {Montrul's book offers a broad overview of research on heritage language acquisition, with particular attention to how heritage speakers develop grammatical knowledge under conditions of reduced input and majority-language pressure. The text brings together findings from linguistics, psycholinguistics, and bilingualism research and explains how heritage speakers differ from both monolingual speakers and second-language learners. This source is especially useful because it provides theoretical background and research synthesis across multiple chapters rather than focusing on a single study. It is relevant to a literature review on heritage language learning because it establishes core concepts, major debates, and recurring patterns in the field.}
}

@inproceedings{muckenhumer2023efficacy,
  author = {Muckenhumer, Christina and Schefer-Wenzl, Sigrid and Miladinovic, Igor},
  title = {Efficacy Analysis of Mobile Language Learning Apps},
  booktitle = {Proceedings of the 9th International Conference on Frontiers of Educational Technologies (ICFET 2023)},
  year = {2023},
  pages = {1--7},
  address = {Bali, Indonesia},
  publisher = {Association for Computing Machinery},
  doi = {10.1145/3606150.3606152},
  url = {https://doi.org/10.1145/3606150.3606152},
  annote = {This conference paper evaluates the effectiveness of several popular mobile language learning applications by comparing findings from existing efficacy studies. The authors focus on Babbel, Busuu, and Duolingo and consider how well each app supports language skill development. The article is useful because it does not simply describe these apps as popular tools, but instead asks whether the available evidence supports claims about their instructional value. For a literature review, this source helps connect the broader topic of mobile-assisted language learning with questions of evidence, comparison, and actual learner outcomes.}
}

@inproceedings{almahmoud2015native,
  author = {Almahmoud, Jumana and Anderson, Mallory and Dewan, Abhishek and Gutierrez, Sofia and Kumarasubramanian, Ram},
  title = {Am I Native Enough? Exploring American Indian Identity through Language Learning},
  booktitle = {Proceedings of the 33rd Annual ACM Conference Extended Abstracts on Human Factors in Computing Systems (CHI EA '15)},
  year = {2015},
  pages = {1427--1432},
  address = {Seoul, Republic of Korea},
  publisher = {Association for Computing Machinery},
  doi = {10.1145/2702613.2726949},
  url = {https://doi.org/10.1145/2702613.2726949},
  annote = {This paper discusses Minowe, an online and mobile learning platform designed to support Ojibwe language learning while also exploring questions of American Indian identity. The authors connect language learning with belonging, self-perception, and community participation, showing that digital tools can serve both educational and cultural purposes. The source is useful because it frames language revitalization as more than a technical problem of instruction; it is also a matter of identity and social connection. It is relevant to a literature review on heritage or Indigenous language learning because it illustrates how design decisions in educational technology can reflect broader cultural goals.}

}

@inproceedings{papadopoulos2013aladdin,
  author = {Papadopoulos, Pantelis M. and Karatsolis, Andreas and Ibrahim, Zeinab},
  title = {Learning Activities, Educational Games, and Tangibles: Arabic Language Learning in the ALADDIN Project},
  booktitle = {Proceedings of the 12th International Conference on Interaction Design and Children (IDC '13)},
  year = {2013},
  pages = {412--415},
  address = {New York, NY, USA},
  publisher = {Association for Computing Machinery},
  doi = {10.1145/2485760.2485834},
  url = {https://doi.org/10.1145/2485760.2485834},
  annote = {This paper presents the ALADDIN project, a technology-enhanced Arabic language learning initiative for young children in Qatar. The authors describe how educational games, story-based learning, and tangible interaction were incorporated into Arabic literacy instruction through tabletop computing. The article is useful because it combines curriculum design, language teaching, and educational technology in a way that is aimed at early learners rather than university students or adult users. It is relevant to a literature review on language learning technology because it shows how digital tools can be designed to support interaction, collaboration, and engagement in early language education.}
}

@article{hoff2018bilingual,
  author = {Hoff, Erika},
  title = {Bilingual Development in Children of Immigrant Families},
  journal = {Child Development Perspectives},
  year = {2018},
  volume = {12},
  number = {2},
  pages = {80--86},
  doi = {10.1111/cdep.12262},
  annote = {Hoff reviews research on bilingual development in children from immigrant families and explains why early exposure to two languages does not automatically lead to balanced bilingual proficiency. She emphasizes the importance of input quantity, input quality, and language use in shaping children's development in both the heritage language and the majority language. This article is useful because it gives a concise explanation of why children in bilingual homes may still show uneven development across languages. It is relevant to a literature review on heritage language learning because it provides a clear developmental perspective on the conditions that support or limit bilingual growth.}
}

@article{hoff2013language_trajectories,
  author = {Hoff, Erika},
  title = {Interpreting the Early Language Trajectories of Children From Low-SES and Language Minority Homes: Implications for Closing Achievement Gaps},
  journal = {Developmental Psychology},
  year = {2013},
  volume = {49},
  number = {1},
  pages = {4--14},
  publisher = {American Psychological Association},
  doi = {10.1037/a0027238}, 
  annote = {In this article, Hoff examines the early language development of children from low-SES and language-minority homes and considers how these patterns relate to later school achievement. She argues that differences in early English oral language skill can have lasting educational consequences, while also stressing that support for English development should not require abandoning children's other languages. This source is useful because it connects language development to broader questions of educational equity and academic opportunity. It is relevant to a literature review on bilingual or heritage language education because it addresses how language background and social context shape early learning trajectories.}
}

@article{gharibi2017factors,
  author = {Gharibi, Kiana},
  title = {Influential Factors in Complete Second Language Acquisition},
  journal = {International Journal of Language and Linguistics},
  year = {2017},
  volume = {4},
  number = {2},
  pages = {50--56}, 
  annote = {This article discusses factors that contribute to successful second language acquisition, drawing attention to variables such as age, motivation, exposure, and learning conditions. Although it is broader than heritage language research specifically, it is still useful because it summarizes major influences that shape language learning outcomes. The source can help provide general background for a literature review by identifying recurring variables that also matter in bilingual and heritage language contexts. Its value lies in offering a straightforward overview of key factors often discussed across language learning research.}

}

@article{montrul2010challenges,
  author = {Montrul, Silvina},
  title = {Challenges and Opportunities for Heritage Language Learners},
  journal = {Heritage Language Journal},
  year = {2010},
  volume = {7},
  number = {1},
  pages = {1--25},
  annote = {In this article, Montrul outlines major challenges and opportunities facing heritage language learners. She explains that heritage learners often arrive in classrooms with uneven skills across speaking, listening, reading, and writing, which means that conventional foreign language instruction may not meet their needs. The article is useful because it directly addresses the educational implications of heritage speaker profiles and argues for more responsive teaching approaches. It is relevant to a literature review on heritage language education because it helps explain why these learners require distinct pedagogical attention.}
}

@inproceedings{multigen2024speech,
  author = {Zhang, Yifan and others},
  title = {MultiGen: Child-Friendly Multilingual Speech Generator with LLMs},
  booktitle = {Proceedings of the Conference on Computational Linguistics},
  year = {2024}, 
  annote = {This conference paper appears to focus on the development of a multilingual speech generation system designed for children and supported by large language models. Although the work is more computational than educational, it may still be relevant if the literature review includes AI tools for multilingual language learning or child-centered language technologies. The source is useful as an example of how newer AI systems are being adapted for multilingual interaction. It fits best in a literature review that includes emerging computational tools rather than only classroom-based heritage language studies.}
}

@article{byrnes2005heritage,
  author = {Byrnes, Heidi},
  title = {Perspectives: The Position of Heritage Languages in Language Education Policy},
  journal = {The Modern Language Journal},
  year = {2005},
  volume = {89},
  number = {4},
  pages = {582--616},
  publisher = {Wiley},
  annote = {This article introduces a policy-oriented discussion of the place of heritage languages in language education. Byrnes situates heritage language issues within broader debates about immigration, identity, national language policy, and educational access in the United States. The source is useful because it helps explain why heritage language instruction is not only a classroom matter but also a political and institutional one. It is relevant to a literature review on heritage language education because it provides context for understanding how policy debates shape what kinds of language programs are supported or marginalized.}
} 